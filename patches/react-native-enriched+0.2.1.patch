+    // PATCH (trendly): the library shipped a bare NSParagraphStyle, so every
+    // paragraph and heading was packed with no inter-block gap or line leading,
+    // looking far tighter than the web (Lexical) editor. Give the base
+    // paragraph style a roomy line height + paragraph spacing to mirror web.
+    // Headings, lists and quotes all mutableCopy this base style, so they
+    // inherit the spacing automatically (no per-style change needed).
+    NSMutableParagraphStyle *baseParagraphStyle =
+        [[NSMutableParagraphStyle alloc] init];
+    baseParagraphStyle.lineHeightMultiple = 1.4;
+    baseParagraphStyle.paragraphSpacing = 12.0;
+    defaultTypingAttributes[NSParagraphStyleAttributeName] = baseParagraphStyle;
