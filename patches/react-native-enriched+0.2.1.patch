@@ -124,6 +124,13 @@ class EnrichedTextInputView : AppCompatEditText {
     setPadding(0, 0, 0, 0)
     setBackgroundColor(Color.TRANSPARENT)
 
+    // PATCH (trendly): the library set no line spacing, so paragraphs and
+    // headings were packed far tighter than the web (Lexical) editor. Add a
+    // roomy line-height multiplier + a small extra gap so blocks breathe,
+    // mirroring iOS (lineHeightMultiple 1.4 + paragraph spacing).
+    val lineSpacingExtra = 4f * resources.displayMetrics.density
+    setLineSpacing(lineSpacingExtra, 1.4f)
+
     addSpanWatcher(EnrichedSpanWatcher(this))
     addTextChangedListener(EnrichedTextWatcher(this))
   }
