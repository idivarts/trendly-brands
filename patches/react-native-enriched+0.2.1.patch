+// PATCH (trendly): replace the text in [start,end] with parsed HTML, scoped to
+// that range. Reuses the parser's existing replaceFromHtml:range: (which sets
+// recentlyChangedRange via TextInsertionUtils and emits onChangeHtml through
+// anyTextMayHaveBeenModified). Powers selection-scoped AI Quick Edit.
+- (void)replaceRange:(NSInteger)start
+                 end:(NSInteger)end
+            fromHtml:(NSString *)html {
+  NSInteger len = (NSInteger)textView.textStorage.string.length;
+  if (start < 0) {
+    start = 0;
+  }
+  if (end > len) {
+    end = len;
+  }
+  if (end < start) {
+    return;
+  }
+  NSString *processed = [parser initiallyProcessHtml:html];
+  if (processed != nullptr) {
+    [parser replaceFromHtml:processed range:NSMakeRange(start, end - start)];
+  }
+}
