+// PATCH (trendly): serialize just the [start,end] range to HTML, returned over
+// the same onRequestHtmlResult channel as requestHTML. Powers fetching the
+// selection's HTML for AI Quick Edit.
+- (void)requestHTMLForRange:(NSInteger)requestId
+                      start:(NSInteger)start
+                        end:(NSInteger)end {
+  auto emitter = [self getEventEmitter];
+  if (emitter != nullptr) {
+    @try {
+      NSInteger len = (NSInteger)textView.textStorage.string.length;
+      NSInteger s = MAX((NSInteger)0, MIN(start, len));
+      NSInteger e = MAX(s, MIN(end, len));
+      NSString *htmlOutput =
+          [parser parseToHtmlFromRange:NSMakeRange(s, e - s)];
+      emitter->onRequestHtmlResult({.requestId = static_cast<int>(requestId),
+                                    .html = [htmlOutput toCppString]});
+    } @catch (NSException *exception) {
+      emitter->onRequestHtmlResult({.requestId = static_cast<int>(requestId),
+                                    .html = folly::dynamic(nullptr)});
+    }
+  }
+}
